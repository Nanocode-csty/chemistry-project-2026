# ============================================
# SUPABASE CONFIGURATION
# Obtén estos valores de: https://app.supabase.com
# Settings > API
# ============================================

# URL de tu proyecto Supabase
# Ejemplo: https://abcdef123456.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clave pública anon
# Busca "anon public" en Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Clave de service role (CONFIDENCIAL)
# ⚠️ NO COMPARTAS ESTO - Busca "service_role secret" en Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# ADMIN CREDENTIALS (Para referencia)
# Estos se crean en Supabase > Authentication > Users
# ============================================

# Email del administrador
NEXT_PUBLIC_ADMIN_EMAIL=admin@escuela-iq.edu

# Contraseña del administrador (cambiar después de crear en Supabase)
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Este archivo NO debe compartirse con otros
# 2. En .gitignore, agrega: .env.local
# 3. En Vercel, agrega las variables en Environment Variables
# 4. Las variables con NEXT_PUBLIC_ son públicas en el cliente
# 5. Las demás solo existen en el servidor

